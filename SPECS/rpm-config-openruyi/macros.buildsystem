%buildsystem_autotools_conf() %configure \\\
                              --disable-silent-rules \\\
                              --disable-rpath \\\
                              --docdir=%{_docdir}/%{name} \\\
                              %*
%buildsystem_autotools_build() %make_build %*
%buildsystem_autotools_install() %make_install %*
%_test_target check
%buildsystem_autotools_check() %make_build %_test_target %*
